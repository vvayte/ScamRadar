# Rename this file to `.env.local` and fill in real values.

# Core app
NEXT_PUBLIC_APP_URL=https://www.scamradar.pro
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NEXT_PUBLIC_SUPPORT_EMAIL=support@scamradar.pro
NEXT_PUBLIC_SECURITY_EMAIL=security@scamradar.pro

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4o-mini

# Stripe — USD (default / rest of world)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_ID_LIFETIME=price_for_lifetime_one_time
STRIPE_PRICE_ID_MONTHLY=price_for_monthly_subscription
STRIPE_PRICE_ID_YEARLY=price_for_yearly_subscription
STRIPE_PRICE_ID_FLASH=price_for_intro_offer_subscription
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe — EUR (Europe). If unset, EU customers fall back to USD prices.
STRIPE_PRICE_ID_LIFETIME_EUR=
STRIPE_PRICE_ID_MONTHLY_EUR=
STRIPE_PRICE_ID_YEARLY_EUR=
STRIPE_PRICE_ID_FLASH_EUR=

# Stripe — GBP (United Kingdom). If unset, UK customers fall back to USD prices.
STRIPE_PRICE_ID_LIFETIME_GBP=
STRIPE_PRICE_ID_MONTHLY_GBP=
STRIPE_PRICE_ID_YEARLY_GBP=
STRIPE_PRICE_ID_FLASH_GBP=

# Abuse-prevention salt for IP fingerprint hashing. MUST be set in production
# to a long random string — leaving it empty makes IP hashes predictable.
IP_HASH_SALT=replace_with_a_long_random_secret

# API protection (optional overrides)
SCAMRADAR_RATE_WINDOW_MS=60000
SCAMRADAR_RATE_MAX_POINTS=24

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js

# Bot integration (required only if using /api/bot/analyze)
BOT_API_TOKEN=replace_with_a_long_random_secret

# Magic-link email delivery (optional, Resend)
REQUIRE_EMAIL_VERIFICATION=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=ScamRadar <noreply@scamradar.pro>
