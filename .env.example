# Rename this file to `.env.local` and fill in real values.

# Core app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4o-mini

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_ID_SUBSCRIPTION=price_for_subscription
STRIPE_PRICE_ID_SINGLE=price_for_single_check
STRIPE_PRICE_ID_PACK=price_for_five_check_pack

# API protection (optional overrides)
SCAMRADAR_RATE_WINDOW_MS=60000
SCAMRADAR_RATE_MAX_POINTS=24

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js

# Bot integration (required only if using /api/bot/analyze)
BOT_API_TOKEN=replace_with_a_long_random_secret

# Magic-link email delivery (optional, Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ScamRadar <no-reply@yourdomain.com>
